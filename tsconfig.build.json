{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/components/**/*", "src/lib/**/*", "src/index.ts"],
  "exclude": ["node_modules", "src/app"]
}
